rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para obtener el perfil del usuario de forma segura
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data;
    }

    // Verificación directa de super usuario por email (no depende del documento de perfil)
    function isSuperUser() {
      return request.auth.token.email.lower() == 'umbralcero7@gmail.com' 
             || request.auth.token.email.lower() == 'amaroisaias611@gmail.com';
    }

    // Función para verificar si el usuario pertenece al comercio (Multi-tenant isolation)
    function belongsToBusiness(data) {
      if (isSuperUser()) { return true; }
      let profile = getProfile();
      return profile != null && (profile.businessId == data.businessId || profile.role == 'SUPPORT');
    }

    // Reglas para la colección de usuarios
    match /users/{email} {
      // Cualquiera puede ver si un usuario existe para el White-list inicial
      allow get: if true;
      // Solo el dueño o soporte puede leer el perfil completo
      allow read: if request.auth != null && (request.auth.token.email.lower() == email.lower() || isSuperUser() || getProfile().role == 'SUPPORT');
      // Solo el dueño puede crear/editar su perfil, pero NO cambiar su propio ROL (prevención de escalada)
      // Los campos sensibles de 2FA (has2FA, totpSecret, backupCodes) solo pueden ser modificados por el propio usuario o super admin
      allow write: if request.auth != null && (request.auth.token.email.lower() == email.lower() || isSuperUser()) && 
                    (resource == null || request.resource.data.role == resource.data.role || isSuperUser() || getProfile().role == 'SUPPORT') &&
                    (request.resource.data.has2FA == resource.data.has2FA || request.auth.token.email.lower() == email.lower() || isSuperUser());
    }

    // Reglas para Facturas (Invoices)
    match /invoices/{invoiceId} {
      allow read: if request.auth != null && belongsToBusiness(resource.data);
      // Solo ADMIN, CASHIER o SUPPORT pueden emitir/editar facturas
      allow write: if request.auth != null && belongsToBusiness(request.resource.data) && 
                    (isSuperUser() || getProfile().role in ['ADMIN', 'CASHIER', 'SUPPORT']);
    }

    // Reglas para el Menú
    match /menu/{productId} {
      allow read: if request.auth != null && belongsToBusiness(resource.data);
      // Solo ADMIN o SUPPORT pueden modificar el menú/precios
      allow write: if request.auth != null && belongsToBusiness(request.resource.data) && 
                    (isSuperUser() || getProfile().role in ['ADMIN', 'SUPPORT']);
    }

    // Reglas para Insumos/Suministros
    match /supplies/{supplyId} {
      allow read: if request.auth != null && belongsToBusiness(resource.data);
      allow write: if request.auth != null && belongsToBusiness(request.resource.data) && 
                    (isSuperUser() || getProfile().role in ['ADMIN', 'SUPPORT']);
    }

    // Reglas para Comandas/Órdenes
    match /orders/{orderId} {
      allow read: if request.auth != null && belongsToBusiness(resource.data);
      // Meseros (WAITER) pueden crear órdenes, Kitchen (CHEF) puede editarlas
      allow write: if request.auth != null && belongsToBusiness(request.resource.data) && 
                    (isSuperUser() || getProfile().role in ['ADMIN', 'WAITER', 'CHEF', 'SUPPORT']);
    }

    // Regla de respaldo: Denegar todo lo demás por defecto.
    // NOTA: collection_stream y otras colecciones internas del SDK son denegadas
    // naturalmente aquí. El SDK maneja estos errores de permiso de forma silenciosa.
    match /{document=**} {
      allow read, write: if request.auth != null && (isSuperUser() || getProfile().role == 'SUPPORT');
    }
  }
}
